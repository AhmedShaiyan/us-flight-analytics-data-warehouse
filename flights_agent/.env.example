# Copy this file to .env and fill in the real values.
# .env is gitignored — never commit it.

# Anthropic API key — obtain from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# GCP project that owns the BigQuery dataset
# Found in dbt SQL files: flight-analytics-portfolio2001
GOOGLE_CLOUD_PROJECT=flight-analytics-portfolio2001

# BigQuery dataset where dbt mart models are materialised
# Check your dbt profiles.yml target schema, e.g. "marts" or "flight_analytics_dbt"
BQ_DATASET=marts

# LLM to use for SQL generation and answer synthesis
# "haiku"  → claude-haiku-4-5-20251001  (faster, cheaper — good for development)
# "sonnet" → claude-sonnet-4-6           (more accurate — good for demos)
LLM_MODE=haiku
